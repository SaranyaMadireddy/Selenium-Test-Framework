<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="SmokeSuite" parallel="classes" thread-count="5">
	<listeners>
		<listener class-name="com.orangehrm.listeners.TestListener" />
	</listeners>
	<test name="SmokeTest">
	<groups>
	<run>
	<include name="smoke"/>
	</run> 
	</groups>
		<classes>
			<class name="com.orangehrm.tests.LoginPageTest" />
			<class name="com.orangehrm.tests.DBVerificationTest" />
			<class name="com.orangehrm.tests.ApiTest" />
		</classes>
	</test>
</suite>